{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 22,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
                "SEAL_BUILD_SEAL_C": "ON",
                "SEAL_BUILD_TESTS": "ON",
                "SEAL_BUILD_EXAMPLES": "ON"
            }
        },
        {
            "name": "win-vs2022-x64",
            "displayName": "Windows VS 2022 (x64)",
            "inherits": "base",
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "win-vs2022-arm64",
            "displayName": "Windows VS 2022 (arm64)",
            "inherits": "base",
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "ARM64",
                "strategy": "set"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "win-vs2026-x64",
            "displayName": "Windows VS 2026 (x64)",
            "inherits": "win-vs2022-x64",
            "generator": "Visual Studio 18 2026"
        },
        {
            "name": "win-vs2026-arm64",
            "displayName": "Windows VS 2026 (arm64)",
