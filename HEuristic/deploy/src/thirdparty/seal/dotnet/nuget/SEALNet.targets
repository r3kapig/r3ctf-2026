<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- For iOS devices (arm64) we need to statically link libsealc.a and libseal.a -->
  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'ios-arm64'">
    <NativeLibrary Include="$(MSBuildThisFileDirectory)../runtimes/ios-arm64/native/libsealc.a"
                  Kind="Static"
                  ForceLoad="True"
                  IsCxx="True" />
    <NativeLibrary Include="$(MSBuildThisFileDirectory)../runtimes/ios-arm64/native/libseal.a"
                  Kind="Static"
                  ForceLoad="True"
                  IsCxx="True" />
  </ItemGroup>

  <!-- For the iOS simulator we statically link libsealc.a and libseal.a. Only
       the arm64 simulator slice is shipped; building a MAUI app for an Intel
       Mac iOS simulator (iossimulator-x64) is not supported. -->
  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'iossimulator-arm64'">
    <NativeLibrary Include="$(MSBuildThisFileDirectory)../runtimes/iossimulator/native/libsealc.a"
                  Kind="Static"
                  ForceLoad="True"
                  IsCxx="True" />
    <NativeLibrary Include="$(MSBuildThisFileDirectory)../runtimes/iossimulator/native/libseal.a"
                  Kind="Static"
                  ForceLoad="True"
                  IsCxx="True" />
  </ItemGroup>
</Project>
